####### Install

install_binary: first FORCE
	@test -d $(INSTALL_ROOT)/usr/bin/ || mkdir -p $(INSTALL_ROOT)/usr/bin/
	$(QINSTALL_PROGRAM) /opt/pokerth/pokerth $(INSTALL_ROOT)/usr/bin/pokerth
	-strip $(INSTALL_ROOT)/usr/bin/pokerth

uninstall_binary: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/bin/pokerth
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/bin/ 


install_data: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/pokerth/data/ || mkdir -p $(INSTALL_ROOT)/usr/share/pokerth/data/
	$(QINSTALL) /opt/pokerth/data/data-copyright.txt $(INSTALL_ROOT)/usr/share/pokerth/data/data-copyright.txt
	$(QINSTALL) /opt/pokerth/data/fonts $(INSTALL_ROOT)/usr/share/pokerth/data/fonts
	$(QINSTALL) /opt/pokerth/data/gfx $(INSTALL_ROOT)/usr/share/pokerth/data/gfx
	$(QINSTALL) /opt/pokerth/data/misc $(INSTALL_ROOT)/usr/share/pokerth/data/misc
	$(QINSTALL) /opt/pokerth/data/sounds $(INSTALL_ROOT)/usr/share/pokerth/data/sounds
	$(QINSTALL) /opt/pokerth/data/translations $(INSTALL_ROOT)/usr/share/pokerth/data/translations

uninstall_data: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/translations
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/sounds
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/misc
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/gfx
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/fonts
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/pokerth/data/data-copyright.txt
