{
  "name": "PokerTH Snap Builder",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/snap",
  "postCreateCommand": "echo 'Snap builder ready. Repo at /opt/pokerth-snap/pokerth. Run: ./build_snap.sh'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-ceintl.vscode-language-pack-de",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}
